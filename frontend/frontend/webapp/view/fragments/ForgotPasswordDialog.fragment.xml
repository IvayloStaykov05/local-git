<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="forgotPasswordDialog"
        class="forgotPasswordDialog"
        title="Forgot Password"
        contentWidth="38rem"
        contentHeight="40rem"
        horizontalScrolling="false"
        verticalScrolling="true"
        stretchOnPhone="true">

        <content>
            <VBox
                class="forgotPasswordContent"
                width="100%"
                justifyContent="Center">

                <Text
                    text="Reset your password using your username or email."
                    class="forgotPasswordSubtitle" />

                <VBox class="forgotPasswordFieldGroup">
                    <Label
                        text="Username or Email"
                        class="forgotPasswordLabel" />
                    <Input
                        id="forgotUsernameOrEmailInput"
                        class="forgotPasswordInput"
                        width="100%"
                        placeholder="Enter username or email" />
                </VBox>

                <VBox class="forgotPasswordFieldGroup">
                    <Label
                        text="New Password"
                        class="forgotPasswordLabel" />
                    <Input
                        id="forgotNewPasswordInput"
                        class="forgotPasswordInput"
                        width="100%"
                        type="Password"
                        placeholder="Enter new password" />
                </VBox>

                <VBox class="forgotPasswordFieldGroup">
                    <Label
                        text="Repeat New Password"
                        class="forgotPasswordLabel" />
                    <Input
                        id="forgotConfirmPasswordInput"
                        class="forgotPasswordInput"
                        width="100%"
                        type="Password"
                        placeholder="Repeat new password" />
                </VBox>

            </VBox>
        </content>

        <beginButton>
            <Button
                text="Cancel"
                press="onCloseForgotPasswordDialog"
                class="forgotPasswordCancelButton" />
        </beginButton>

        <endButton>
            <Button
                text="Change Password"
                press="onSubmitForgotPassword"
                class="forgotPasswordSubmitButton" />
        </endButton>

    </Dialog>
</core:FragmentDefinition>