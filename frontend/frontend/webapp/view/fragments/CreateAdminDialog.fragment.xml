<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

   <Dialog
    id="createAdminDialog"
    title="Invite User To Become Admin"
    contentWidth="620px"
    contentHeight="auto"
    draggable="true"
    resizable="false"
    verticalScrolling="true"
    horizontalScrolling="false"
    class="adminCreateDialog">

        <content>
            <VBox class="adminCreateDialogContent">

                <VBox class="adminCreateIntroBox">
                    <Title text="Send admin invitation" level="H4" class="adminCreateTitle" />
                    <Text
                        text="Enter the username of an existing user. The system will send an invitation through inviteToBecomeAdmin, and the invited user will create their admin profile only after accepting it."
                        wrapping="true"
                        class="adminCreateSubtitle" />
                </VBox>

                <VBox class="adminCreateFormGrid">
                    <Label text="User username" class="adminCreateLabel" />
                    <Input id="createAdminUsernameInput" placeholder="Enter existing username" class="adminCreateInput" />
                </VBox>

            </VBox>
        </content>

        <buttons>
            <Button
                text="Close"
                press=".onCloseCreateAdminDialog"
                class="adminSecondaryDialogButton" />

            <Button
                text="Send Invitation"
                press=".onSubmitCreateAdmin"
                class="adminPrimaryDialogButton" />
        </buttons>
    </Dialog>
</core:FragmentDefinition>