<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="adminDeleteDocumentDialog"
        title="Delete Options"
        contentWidth="620px"
        draggable="true"
        resizable="false"
        verticalScrolling="true"
        horizontalScrolling="false"
        class="adminDeleteDialog">

        <content>
            <VBox class="adminDeleteDialogContent">

                <VBox class="adminDeleteIntroBox">
                    <Title
                        text="{= 'Manage deletion for ' + ${admin>/deleteDialog/title} }"
                        level="H4"
                        class="adminDeleteDialogTitle" />

                    <Text
                        text="{= 'This document has ' + ${admin>/deleteDialog/versionsCount} + ' version(s). You can delete a specific version or delete the whole document.' }"
                        wrapping="true"
                        class="adminDeleteDialogSubtitle" />
                </VBox>

                <VBox class="adminDeleteVersionsWrapper">
                    <Title text="Available Versions" level="H5" class="adminDeleteSectionTitle" />

                    <List
                        items="{admin>/deleteDialog/versions}"
                        showSeparators="None"
                        class="adminDeleteVersionsList">

                        <CustomListItem>
                            <HBox class="adminDeleteVersionItem" justifyContent="SpaceBetween" alignItems="Center">
                                <VBox class="adminDeleteVersionTextBox">
                                    <Text
                                        text="{= 'Version ' + ${admin>versionNumber} }"
                                        class="adminDeleteVersionNumber" />
                                    <Text
                                        text="{= 'Status: ' + ${admin>status} }"
                                        class="adminDeleteVersionMeta" />
                                    <Text
                                        text="{= ${admin>createdBy} ? 'Created by: ' + ${admin>createdBy} : '' }"
                                        class="adminDeleteVersionMeta" />
                                    <Text
                                        text="{ path: 'admin>createdAt', formatter: '.formatDateTime' }"
                                        class="adminDeleteVersionMeta" />
                                </VBox>

                                <Button
                                    text="Delete"
                                    press=".onDeleteVersionPress"
                                    enabled="{ path: 'admin>/deleteDialog/versionsCount', formatter: '.formatVersionDeleteEnabled' }"
                                    class="adminDeleteVersionButton" />
                            </HBox>
                        </CustomListItem>
                    </List>
                </VBox>
            </VBox>
        </content>

        <buttons>
            <Button
                text="Delete Document"
                press=".onDeleteWholeDocumentFromDialog"
                class="adminDeleteDocumentButton" />

            <Button
                text="Close"
                press=".onCloseDeleteDocumentDialog"
                class="adminDeleteCloseButton" />
        </buttons>
    </Dialog>
</core:FragmentDefinition>